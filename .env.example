# ============================================================
# GRANT PRIME — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to GitHub — it's in .gitignore
# ============================================================

# ── Required by ALL agents and server.js ────────────────────
SUPABASE_URL=https://pbkzjfzeazkfqxnjnari.supabase.co
SUPABASE_KEY=your_supabase_service_role_key_here

# ── Required by: scoring, strategy agents ───────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Required by: strategy, alert, deadline, treagent, server ─
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=treagent1@gmail.com
ALERT_EMAIL=treagent1@gmail.com

# ── Optional: discovery agent (falls back to public endpoints) ─
GRANTS_GOV_API_KEY=your_grants_gov_api_key_here
SAM_GOV_API_KEY=your_sam_gov_api_key_here

# ── GitHub Actions Secrets (set in repo Settings > Secrets) ──
# All of the above must also be set as GitHub Secrets for
# daily-agents.yml to run. Variable names are identical.
# See: https://github.com/axiom-federal-solutions/grant-prime/settings/secrets/actions
